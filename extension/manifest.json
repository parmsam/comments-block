{
  "manifest_version": 3,
  "name": "Comments Block",
  "version": "1.0",
  "description": "Hide YouTube comments and recommendations",
  "permissions": ["storage"],
  "host_permissions": ["*://www.youtube.com/*"],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon-16.png",
    "32": "icon-32.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon-16.png",
      "32": "icon-32.png",
      "48": "icon-48.png",
      "128": "icon-128.png"
    }
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "comments-block@parmsam",
      "strict_min_version": "109.0"
    }
  }
}
