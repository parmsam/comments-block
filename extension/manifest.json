{
  "manifest_version": 3,
  "name": "Comments Block",
  "version": "1.0",
  "description": "Hide YouTube comments and recommendations",
  "permissions": ["storage"],
  "host_permissions": ["*://www.youtube.com/*"],
  "content_scripts": [
    {
      "matches": ["*://www.youtube.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
